# Backend
DATABASE_PATH=api/assistant.db
UPLOAD_DIR=api/uploads
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=1440

# The owner account is seeded as admin when the API starts.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-a-strong-password

# Keep true for early testing. Set false once users are provisioned another way.
ALLOW_SIGNUPS=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model provider: mock, openai, anthropic, or claude
MODEL_PROVIDER=mock
MODEL_NAME=mock-local
SYSTEM_PROMPT=You are a helpful, careful AI assistant. Be concise, honest, and practical.
MODEL_TIMEOUT_SECONDS=45
MODEL_MAX_RETRIES=2
MODEL_TEMPERATURE=0.4
MODEL_MAX_OUTPUT_TOKENS=2048
MAX_INLINE_IMAGE_BYTES=5242880

# OpenAI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude/Anthropic provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
