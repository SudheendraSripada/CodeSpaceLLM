# Backend
DATABASE_PATH=api/assistant.db
UPLOAD_DIR=api/uploads
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_MINUTES=1440
AUTH_PROVIDER=local
DATA_BACKEND=sqlite

# The owner account is seeded as admin when the API starts.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-a-strong-password

# Keep true for early testing. Set false once users are provisioned another way.
ALLOW_SIGNUPS=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model provider: mock, openai, anthropic, claude, openrouter, groq, ollama, or openai-compatible
MODEL_PROVIDER=openrouter
MODEL_NAME=qwen/qwen3-32b
SYSTEM_PROMPT=You are a helpful, careful AI assistant. Be concise, honest, and practical.
MODEL_TIMEOUT_SECONDS=45
MODEL_MAX_RETRIES=2
MODEL_TEMPERATURE=0.4
MODEL_MAX_OUTPUT_TOKENS=2048
MAX_INLINE_IMAGE_BYTES=5242880

# OpenAI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI-compatible providers for Qwen/Gemma style hosted models
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Claude/Anthropic provider
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Supabase auth, Postgres, and storage
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=assistant-files

# Frontend
API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
